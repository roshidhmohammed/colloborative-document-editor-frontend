{
  "name": "colloborative-doc-editor",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NODE_ENV=development dotenv -e .env.development -- next dev",
    "build": "next build",
    "start": "cross-env NODE_ENV=production dotenv -e .env.production -- next start",
    "test": "cross-env NODE_ENV=testing dotenv -e .env.testing -- jest",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "test:unit": "cross-env NODE_ENV=testing dotenv -e .env.testing -- jest __tests__/unit",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "cross-env NODE_ENV=testing dotenv -e .env.testing -- playwright test",
    "test:e2e:ci": "cross-env NODE_ENV=testing dotenv -e .env.testing playwright test --reporter=github",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@reduxjs/toolkit": "^2.12.0",
    "@tanstack/react-query": "^5.101.1",
    "@tanstack/react-query-devtools": "^5.101.1",
    "@testing-library/user-event": "^14.6.1",
    "@tiptap/extension-highlight": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-typography": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "axios": "^1.18.1",
    "clsx": "^2.1.1",
    "dotenv-cli": "^11.0.0",
    "idb": "^8.0.3",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.80.0",
    "react-icons": "^5.7.0",
    "react-redux": "^9.3.0",
    "server-only": "^0.0.1",
    "socket.io-client": "^4.8.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "y-prosemirror": "^1.3.7",
    "yjs": "^13.6.31",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "postcss": "^8.5.17",
    "socket.io": "^4.8.3",
    "tailwindcss": "^4.3.2",
    "ts-node": "^10.9.2",
    "typescript": "^5"
  }
}
